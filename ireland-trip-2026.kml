  <Folder>
    <name>Attractions</name>
    <!-- Dublin -->
    <Placemark><name>Kilmainham Gaol</name><description>1916 Rising executions. €8 (~$9), book 28 days ahead</description><styleUrl>#attraction</styleUrl><Point><coordinates>-6.3100,53.3420</coordinates></Point></Placemark>
    <Placemark><name>Collins Barracks</name><description>Free. Proclaiming a Republic exhibition</description><styleUrl>#attraction</styleUrl><Point><coordinates>-6.2870,53.3480</coordinates></Point></Placemark>
    <Placemark><name>GPO &amp; Witness History</name><description>1916 rebel HQ. O'Connell St, Dublin</description><styleUrl>#attraction</styleUrl><Point><coordinates>-6.2600,53.3490</coordinates></Point></Placemark>
    <Placemark><name>Glasnevin Cemetery</name><description>de Valera, Collins, Markievicz graves. Free grounds</description><styleUrl>#attraction</styleUrl><Point><coordinates>-6.2760,53.3720</coordinates></Point></Placemark>
    <Placemark><name>EPIC Emigration Museum</name><description>Interactive. ~€17 (~$19). CHQ Building, Dublin</description><styleUrl>#attraction</styleUrl><Point><coordinates>-6.2480,53.3490</coordinates></Point></Placemark>
    <Placemark><name>Kevin &amp; Howlin</name><description>Donegal tweed since 1936. 31 Nassau St, Dublin</description><styleUrl>#attraction</styleUrl><Point><coordinates>-6.2570,53.3420</coordinates></Point></Placemark>
    <Placemark><name>Celtic Tweed</name><description>Tailored tweed &amp; linen, made in Dublin. South Anne's Lane</description><styleUrl>#attraction</styleUrl><Point><coordinates>-6.2590,53.3415</coordinates></Point></Placemark>
    <!-- En route Dublin-Galway -->
    <Placemark><name>Kilbeggan Distillery</name><description>Ireland's oldest (1757). €35 (~$38) tour w/ fill-your-own bottle. Right off M6</description><styleUrl>#attraction</styleUrl><Point><coordinates>-7.5000,53.3700</coordinates></Point></Placemark>
    <!-- Galway -->
    <Placemark><name>Charlie Byrne's Bookshop</name><description>35,000+ titles. Middle St, Galway</description><styleUrl>#attraction</styleUrl><Point><coordinates>-9.0560,53.2710</coordinates></Point></Placemark>
    <Placemark><name>Spanish Arch</name><description>16th-century arch, Long Walk views. Galway</description><styleUrl>#attraction</styleUrl><Point><coordinates>-9.0540,53.2695</coordinates></Point></Placemark>
    <Placemark><name>Galway City Museum</name><description>Free. Local history, archaeology, art</description><styleUrl>#attraction</styleUrl><Point><coordinates>-9.0545,53.2698</coordinates></Point></Placemark>
    <!-- Near Galway -->
    <Placemark><name>Standun (Spiddal)</name><description>Family-run wool shop since 1946. Aran sweaters, tweed, cafe. 20 min west of Galway</description><styleUrl>#attraction</styleUrl><Point><coordinates>-9.3050,53.2420</coordinates></Point></Placemark>
    <Placemark><name>Dunguaire Castle (EXTERIOR ONLY)</name><description>Closed since 2022 for repairs. Photo op from road only — cannot enter. On Kinvara Bay.</description><styleUrl>#attraction</styleUrl><Point><coordinates>-8.9240,53.1420</coordinates></Point></Placemark>
    <!-- Burren / Clare -->
    <Placemark><name>Poulnabrone Dolmen</name><description>5,800-year-old portal tomb. Free, Burren. Pull over, 5-min walk</description><styleUrl>#attraction</styleUrl><Point><coordinates>-9.1400,53.0490</coordinates></Point></Placemark>
    <Placemark><name>Burren Perfumery</name><description>Free admission, 10am-5pm. Carran, Burren</description><styleUrl>#attraction</styleUrl><Point><coordinates>-9.0800,53.0600</coordinates></Point></Placemark>
    <Placemark><name>Cliffs of Moher</name><description>214m sea cliffs. €8 (~$9), 1-2 hours. 10 min from Doolin</description><styleUrl>#attraction</styleUrl><Point><coordinates>-9.4260,52.9720</coordinates></Point></Placemark>
    <!-- Dingle Peninsula -->
    <Placemark><name>Connor Pass</name><description>Highest mountain pass in Ireland. Dramatic views</description><styleUrl>#attraction</styleUrl><Point><coordinates>-10.1200,52.1700</coordinates></Point></Placemark>
    <Placemark><name>Slea Head Drive (start)</name><description>38km scenic loop, 2.5-3.5 hours. Drive clockwise to avoid tour buses</description><styleUrl>#attraction</styleUrl><Point><coordinates>-10.2700,52.1400</coordinates></Point></Placemark>
    <Placemark><name>Fahan Beehive Huts</name><description>2,000-year-old stone huts. €4 (~$4). Baby lambs!</description><styleUrl>#attraction</styleUrl><Point><coordinates>-10.4200,52.1150</coordinates></Point></Placemark>
    <Placemark><name>Dunmore Head</name><description>Westernmost point of mainland Ireland. Short walk from car park</description><styleUrl>#attraction</styleUrl><Point><coordinates>-10.4700,52.1050</coordinates></Point></Placemark>
    <Placemark><name>Gallarus Oratory</name><description>7th-century dry-stacked stone chapel, still watertight after 1,300 years</description><styleUrl>#attraction</styleUrl><Point><coordinates>-10.3530,52.1710</coordinates></Point></Placemark>
    <Placemark><name>Blasket Centre</name><description>Museum of Great Blasket island community. €5 (~$5), Dunquin</description><styleUrl>#attraction</styleUrl><Point><coordinates>-10.4600,52.1200</coordinates></Point></Placemark>
    <!-- Kerry -->
    <Placemark><name>Muckross House &amp; Gardens</name><description>Victorian mansion, free gardens. On the way Dingle-Cork via Killarney</description><styleUrl>#attraction</styleUrl><Point><coordinates>-9.5050,52.0200</coordinates></Point></Placemark>
    <Placemark><name>Gap of Dunloe</name><description>Glacial valley, Wishing Bridge (30-min round trip). Free parking at Kate Kearney's Cottage</description><styleUrl>#attraction</styleUrl><Point><coordinates>-9.6500,51.9900</coordinates></Point></Placemark>
    <Placemark><name>Ladies View</name><description>Famous viewpoint on N71. Free, just pull over. Killarney area</description><styleUrl>#attraction</styleUrl><Point><coordinates>-9.6800,51.9700</coordinates></Point></Placemark>
    <!-- Cork -->
    <Placemark><name>English Market</name><description>Covered market since 1788. Free, Mon-Sat 8am-6pm. Cork City</description><styleUrl>#attraction</styleUrl><Point><coordinates>-8.4780,51.8970</coordinates></Point></Placemark>
    <Placemark><name>Shandon Bells &amp; Tower</name><description>Ring bells yourself. €5 (~$5). Views over Cork rooftops</description><styleUrl>#attraction</styleUrl><Point><coordinates>-8.4790,51.9020</coordinates></Point></Placemark>
    <Placemark><name>Nano Nagle Place</name><description>Heritage centre &amp; gardens. Cork City</description><styleUrl>#attraction</styleUrl><Point><coordinates>-8.4820,51.8950</coordinates></Point></Placemark>
    <Placemark><name>Fitzgerald Park &amp; Cork Public Museum</name><description>Free admission. Cork City</description><styleUrl>#attraction</styleUrl><Point><coordinates>-8.4950,51.8940</coordinates></Point></Placemark>
    <Placemark><name>Triskel Arts Centre</name><description>Arts venue. Cork City</description><styleUrl>#attraction</styleUrl><Point><coordinates>-8.4770,51.8960</coordinates></Point></Placemark>
    <!-- Kinsale -->
    <Placemark><name>Charles Fort</name><description>17th-century star fort. €5 (~$5). Scilly Walk access</description><styleUrl>#attraction</styleUrl><Point><coordinates>-8.5020,51.6970</coordinates></Point></Placemark>
    <!-- Cork region -->
    <Placemark><name>Cobh Heritage Centre</name><description>Last port for Titanic. Heritage town with cathedral</description><styleUrl>#attraction</styleUrl><Point><coordinates>-8.2960,51.8510</coordinates></Point></Placemark>
    <Placemark><name>Spike Island</name><description>Prison history, Cork Harbor</description><styleUrl>#attraction</styleUrl><Point><coordinates>-8.2810,51.8380</coordinates></Point></Placemark>
    <Placemark><name>Jameson Experience Midleton</name><description>Whiskey distillery tour. 20 min from Cork</description><styleUrl>#attraction</styleUrl><Point><coordinates>-8.1750,51.9140</coordinates></Point></Placemark>
    <Placemark><name>Fota Wildlife Park</name><description>Animal park. Between Cork and Cobh</description><styleUrl>#attraction</styleUrl><Point><coordinates>-8.3080,51.8920</coordinates></Point></Placemark>
    <!-- West Cork -->
    <Placemark><name>Timoleague Friary</name><description>13th-century Franciscan ruin. Free. West Cork</description><styleUrl>#attraction</styleUrl><Point><coordinates>-8.7730,51.6380</coordinates></Point></Placemark>
    <Placemark><name>Michael Collins House</name><description>War of Independence. Tue-Sat 10am-5pm. Clonakilty</description><styleUrl>#attraction</styleUrl><Point><coordinates>-8.8870,51.6230</coordinates></Point></Placemark>
    <!-- Return route -->
    <Placemark><name>Rock of Cashel</name><description>Medieval cathedral cluster. €8 (~$9). Tipperary, on M8 back to Dublin</description><styleUrl>#attraction</styleUrl><Point><coordinates>-7.8900,52.5200</coordinates></Point></Placemark>
    <Placemark><name>Cahir Castle</name><description>13th-century, best-preserved medieval castle. €5 (~$5). Tipperary</description><styleUrl>#attraction</styleUrl><Point><coordinates>-7.9270,52.3750</coordinates></Point></Placemark>
    <Placemark><name>Kilkenny Castle</name><description>13th-century castle, free OPW grounds. Medieval city</description><styleUrl>#attraction</styleUrl><Point><coordinates>-7.2490,52.6500</coordinates></Point></Placemark>
  </Folder>

