    <Placemark><name>Kai Restaurant</name><description>Vegetable-forward, small seasonal menu. Sea Road, Galway</description><styleUrl>#food</styleUrl><Point><coordinates>-9.0590,53.2720</coordinates></Point></Placemark>
    <Placemark><name>Dela</name><description>Counter-service, lighter meals. Dominick St, Galway</description><styleUrl>#food</styleUrl><Point><coordinates>-9.0570,53.2730</coordinates></Point></Placemark>
    <Placemark><name>Bierhaus</name><description>Fully vegetarian gastropub. Henry St, Galway</description><styleUrl>#food</styleUrl><Point><coordinates>-9.0530,53.2720</coordinates></Point></Placemark>
    <Placemark><name>Micil Distillery</name><description>6th gen family poitin/whiskey. 75-min tours, Salthill, Galway</description><styleUrl>#food</styleUrl><Point><coordinates>-9.0750,53.2600</coordinates></Point></Placemark>
