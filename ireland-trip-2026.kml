    <Placemark><name>The Winding Stair</name><description>Irish seasonal, river views. 40 Lower Ormond Quay, Dublin</description><styleUrl>#food</styleUrl><Point><coordinates>-6.2650,53.3470</coordinates></Point></Placemark>
    <Placemark><name>Keogh's Cafe</name><description>Breakfast, opens 6:30 AM. 1-2 Trinity St, Dublin</description><styleUrl>#food</styleUrl><Point><coordinates>-6.2600,53.3430</coordinates></Point></Placemark>
    <Placemark><name>Palace Bar</name><description>100+ Irish whiskeys, traditional pub. 21 Fleet St, Dublin</description><styleUrl>#food</styleUrl><Point><coordinates>-6.2600,53.3450</coordinates></Point></Placemark>
