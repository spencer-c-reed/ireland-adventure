  <Folder>
    <name>Lodging (Booked)</name>
    <Placemark><name>Sheedy's B&amp;B (Wed night - BOOKED)</name><description>Doolin. #1 B&amp;B in Ireland (TripAdvisor). River views, feather duvets. sheedysdoolin.com</description><styleUrl>#lodging</styleUrl><Point><coordinates>-9.3780,52.9960</coordinates></Point></Placemark>
    <Placemark><name>Pax House (Thu night - BOOKED)</name><description>Dingle. #1 Dingle, #2 Europe. Exceptional breakfast, Dingle Bay views. +353 66 915 1518</description><styleUrl>#lodging</styleUrl><Point><coordinates>-10.2750,52.1380</coordinates></Point></Placemark>
  </Folder>

